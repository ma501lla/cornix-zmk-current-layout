#include "zmk-helpers/helper.h"
#include "includes/cornix54.h"

// tap windows for ctl alt and gui

// filterpaper 流タイミング設定 (2026-05 移行)
// 参考: https://github.com/filterpaper/zmk-config
#define HM_TAPPING_TERM 225           // filterpaper 流: 225ms
#define HM_TAPPING_REPEAT 210

// quick tapping for shift

// Shift 専用 HM タップ判定時間: filterpaper 流 165ms 採用
// hm_shift_l/r は require-prior-idle-ms = 0 として Townk 流の即時 Shift 化
// (V→Shift+letter 等の Vim 高頻度操作で Shift が直前入力に関係なく確実に成立)
#define HM_TAPPING_TERM_FAST 165
#define HM_PRIOR_IDLE 105             // filterpaper 流: 105ms (旧 70ms から増加で誤爆抑止強化)
#define BASE   0
#define LOWER  1
#define RAISE  2
#define ADJUST 3
#define NAVI   4
#define NUM    5
#define DEBUG  6

// https://github.com/urob/zmk-config/tree/main#timeless-homerow-mods

#define KEYS_L LT0 LT1 LT2 LT3 LT4 LT5 LM0 LM1 LM2 LM3 LM4 LM5 LB0 LB1 LB2 LB3 LB4 LB5  // left hand
#define KEYS_R RT0 RT1 RT2 RT3 RT4 RT5 RM0 RM1 RM2 RM3 RM4 RM5 RB0 RB1 RB2 RB3 RB4 RB5  // right hand
#define THUMBS LH1 LH0 RH0 RH1
#define KEYS_T LH1 LH0 RH0 RH1
#define ZMK_POINTING_DEFAULT_SCRL_VAL 15

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/keys.h>

/ {
    // Activate ADJUST layer by pressing raise and lower

    behaviors {
        hm_l: homerow_mods_left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&kp>, <&kp>;

            flavor = "balanced";
            tapping-term-ms = <HM_TAPPING_TERM>;
            quick-tap-ms = <105>;                // filterpaper 流: 連打レスポンス改善
            require-prior-idle-ms = <HM_PRIOR_IDLE>;
            hold-trigger-key-positions = <KEYS_R KEYS_T>;
            hold-trigger-on-release;
        };

        hm_r: homerow_mods_right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&kp>, <&kp>;

            flavor = "balanced";
            tapping-term-ms = <HM_TAPPING_TERM>;
            quick-tap-ms = <105>;
            require-prior-idle-ms = <HM_PRIOR_IDLE>;
            hold-trigger-key-positions = <KEYS_L KEYS_T>;
            hold-trigger-on-release;
        };

        // Positional Homerow mods for shift
        // Use faster tapping term and disable some features that may
        // cause false negatives.

        // Shift 専用 HM: Townk 流に require-prior-idle-ms = 0 で即時 Shift 化
        // (V→Shift+letter 等の Vim 高頻度操作で直前入力に関係なく成立)
        hm_shift_l: hm_shift_l {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&kp>, <&kp>;

            flavor = "balanced";
            tapping-term-ms = <HM_TAPPING_TERM_FAST>;
            quick-tap-ms = <105>;
            require-prior-idle-ms = <0>;
            hold-trigger-key-positions = <KEYS_R KEYS_T>;
            hold-trigger-on-release;
        };

        hm_shift_r: hm_shift_r {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&kp>, <&kp>;

            flavor = "balanced";
            tapping-term-ms = <HM_TAPPING_TERM_FAST>;
            quick-tap-ms = <105>;
            require-prior-idle-ms = <0>;
            hold-trigger-key-positions = <KEYS_L KEYS_T>;
            hold-trigger-on-release;
        };

        /*
         * Non-Positional Homerow Mods
         * Used for &mm_grescm_gui behavior on left hand.
         *
         * Usage: &hm LSHFT T
         * Tap: T
         * Tap-Tap-Hold: Repeat T
         * Hold: LSHIFT
         */

        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&kp>, <&kp>;

            flavor = "balanced";
            tapping-term-ms = <HM_TAPPING_TERM>;
            quick-tap-ms = <200>;
        };

        bs_del: bs_del {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp BSPC>, <&kp DEL>;

            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        lt: layer_tap {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&mo>, <&kp>;

            flavor = "hold-preferred";
            tapping-term-ms = <HM_TAPPING_TERM>;
            quick-tap-ms = <200>;
        };

        // lt_g: tap-preferred layer-tap (used for G → Navi)
        // 値は main ブランチ準拠 (filterpaper 流の HM 定数を継承せず固定)
        // ユーザの打鍵感覚で main の挙動が最も自然と確認済み (2026-05-29)
        lt_g: layer_tap_g {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&mo>, <&kp>;

            flavor = "tap-preferred";
            tapping-term-ms = <250>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <70>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        adjust_layer {
            if-layers = <2 1>;
            then-layer = <3>;
        };
    };

    combos {
        compatible = "zmk,combos";

        cb_kp_esc {
            bindings = <&kp ESC>;
            key-positions = <2 1>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        // TAB: 旧 W+R (2+4) から S+F (14+16) へ移設 (ユーザ指定 2026-05-28)
        cb_kp_tab {
            bindings = <&kp TAB>;
            key-positions = <13 15>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        // base レイヤーの SQT 廃止に伴う代替: K + ; (位置 20+22) で ' を発射
        // L を飛ばしたペアなので Vim 操作中の誤爆リスク最小
        cb_kp_sqt {
            bindings = <&kp SQT>;
            key-positions = <21 23>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        // cb_kp_enter 削除 (2026-05-28): 位置 23 が &none で動作せず、Enter は親指 (位置 44) で取得可能
        // cb_bs_del 削除済み: layer 6 廃止に伴い消滅
        // → BS は新規 cb_kp_bs (I+O) で再実装、bs_del morph で Shift+BS = DEL も兼ねる

        cb_kp_bs {
            bindings = <&bs_del>;
            key-positions = <9 10>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        // J + ; → Enter (2026-05-29 追加)
        // cb_kp_sqt (K+;) と位置 22 を共有するが相手キーが異なるため競合なし
        cb_kp_enter {
            bindings = <&kp ENTER>;
            key-positions = <20 23>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_kp_space {
            bindings = <&kp SPACE>;
            key-positions = <16 28>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        my_combo_keypress_zenhan {
            bindings = <&my_macro_zenhan>;
            key-positions = <2 3>;
            require-prior-idle-ms = <150>;
        };

        // 旧 vertical 括弧 combo 8 個 (< > [ ] { } ( )) は 2026-05-29 に撤去
        // 縦コンボの打鍵感が悪く、Symbols レイヤー上段に集約 (< > [ ] { } はキー、( ) は既存ホームロウ)

        // cb_kp_r-ctrl / shift / alt 削除:
        // 右手 HM (J=RSHFT, K=RGUI, L=RALT, ;=RCTRL) で恒常的に修飾キーアクセス可能になったため不要

        cb_kp_insert {
            bindings = <&kp INS>;
            key-positions = <20 10>;
            require-prior-idle-ms = <150>;
        };

        // レイヤー起動 combo 4 種を削除 (2026-06):
        //   Symbols(&mo 1): xc (X+C) / ,. (comma+dot)  ← 旧 cb_layer2_fz / cb_layer2_jslash
        //   Mix(&mo 2):     fz (F+Z) / j/ (J+slash)     ← 旧 cb_layer3_cx / cb_layer3_commadot
        //   レイヤーは親指キー (mo 1 / mo 2) で引き続きアクセス可能。
        //   これにより ,. (<35 36>) は cb_rgui (RGUI) のみとなり位置重複も解消。

        // === 修飾キー combo (2026-05-28 追加: 完全 combo 主義) ===
        // bindings = <&kp LXXX> による直接 hold 方式
        //   - combo を保持中 → 修飾キー保持 (連続操作対応)
        //   - combo タップ × 2 → IDE の Ctrl-Ctrl 等の二連打検出に対応
        //   - 複数 combo 同時保持 → Ctrl+Alt 等の sustained 多重修飾
        // 左手内 Shift+Ctrl 同時保持可 (A+S+D+F の 4 指)
        // 右手内 Shift+Ctrl 同時保持可 (U+I+O+P の 4 指)

        cb_lshft {
            bindings = <&kp LSHFT>;
            key-positions = <12 13>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_lctrl {
            bindings = <&kp LCTRL>;
            key-positions = <14 15>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_lalt {
            bindings = <&kp LALT>;
            key-positions = <12 14>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_lgui {
            bindings = <&kp LGUI>;
            key-positions = <24 25>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_rshft {
            bindings = <&kp RSHFT>;
            key-positions = <8 9>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_rctrl {
            bindings = <&kp RCTRL>;
            key-positions = <10 11>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_ralt {
            bindings = <&kp RALT>;
            key-positions = <34 35>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };

        cb_rgui {
            bindings = <&kp RGUI>;
            key-positions = <35 36>;
            layers = <0>;
            require-prior-idle-ms = <150>;
        };
    };

    macros {
        my_macro_zenhan: my_macro_zenhan {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_ALT>,
                <&macro_tap>,
                <&kp GRAVE>,
                <&macro_release>,
                <&kp LEFT_ALT>;

            label = "MY_MACRO_ZENHAN";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";

            // ------------------------------------------------------------------------------------------------------------
            // 36-key 有効レイアウト (filterpaper 流 / Vim フレンドリー) — ホームポジション外側シフト版 (2026-06)
            // 内周列 (5/17/29 左・6/18/32 右) と外側親指 (38-40/47-49) を意図的に &none。文字を外側5列へ寄せた
            // 2026-05-28: HM 全撤廃 (filterpaper 流の打鍵リズム不適合・誤発火事故発生のため)
            // 修飾キーアクセスは combo / 親指レイヤー / 既存 Symbols レイヤーで代替する方針へ
            // ('は K+; combo で発射、内周は &none)
            //
            // |  Q  |  W  |  E   |  R   |  T   |  -  |                   |  -  |  Y   |  U   |  I   |  O   |  P  |
            // |  A  |  S  |  D   |  F   |  G   |  -  |                   |  -  |  H   |  J   |  K   |  L   |  ;  |
            // |  Z  |  X  |  C   |  V   |  B   |  -  |  MUTE  |  |       |  -  |  N   |  M   |  ,   |  .   |  /  |
            //               |  -  |  -  | ESC/L5| L1  | SPACE/L4 |  | ENTER | L2 | BSPC/L1 |  -  |  -  |

            bindings = <
&kp Q  &kp W  &kp E  &kp R         &kp T      &none                                &none      &kp Y  &kp U            &kp I     &kp O     &kp P
&kp A  &kp S  &kp D  &kp F         &lt_g 4 G  &none                                &none      &kp H  &kp J            &kp K     &kp L     &kp SEMICOLON
&kp Z  &kp X  &kp C  &kp V         &kp B      &none        &kp KP_NUMBER_0  &none  &none      &kp N  &kp M            &kp COMMA &kp DOT   &kp FSLH
&none  &none  &none  &lt 5 ESCAPE  &mo 1      &lt 4 SPACE                          &kp ENTER  &mo 2  &lt 1 BACKSPACE  &none     &none     &none
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp PG_UP PG_DN>;
        };

        Symbol_layer {
            display-name = "Symbols";

            // TODO: Some binds are waiting for shifted keycode support.
            // -------------------------------
            // |       |  F1 |  F2 |  F3  |  F4  |  F5  |                   |  F6  |  F7   |  F8   |  F9  |  F10  |  F11  |
            // |   `   |  1  |  2  |  3   |  4   |  5   |                   |  6   |  7    |  8    |  9   |   0   |  F12  |
            // |       |  !  |  @  |  #   |  $   |  %   |                   |  ^   |  &    |  *    |  (   |   )   |   |   |
            // |       |  =  |  -  |  +   |  {   |  }   |        |  |       |  [   |  ]    |  ;    |  :   |   \   |       |
            //               |     |      |      |      |        |  |       |      |       |       |      |

            // 上段: 括弧類を集約 (2026-05-29、旧 vertical combo の代替)
            //   左 5 キー (Q W E R T) + Y に < > [ ] { } を配置
            //   右半身は - = \ ` の既存配置を維持
            // ホーム行: Shift+数字の記号 (! @ # $ % ^ & * ( )) — 変更なし
            //   ( ) はホーム行末尾 (L, ;) に既配置
            // 下段: 旧 LEFT_SHIFT / RIGHT_SHIFT は combo Shift で代替可能となったため除去
            bindings = <
&kp LT           &kp GT       &kp LBKT  &kp RBKT    &kp LBRC     &to 0                                    &kp GRAVE        &kp RBRC       &none         &kp MINUS             &kp EQUAL              &kp BACKSLASH
&kp EXCLAMATION  &kp AT_SIGN  &kp HASH  &kp DOLLAR  &kp PERCENT  &none                                    &none            &kp CARET      &kp AMPERSAND  &kp ASTERISK         &kp LEFT_PARENTHESIS   &kp RIGHT_PARENTHESIS
&none            &none        &none     &none       &none        &none           &kp KP_NUMBER_2  &trans  &none            &none          &none         &none                 &none                  &none
&none            &none        &none     &none       &trans       &kp LEFT_SHIFT                           &kp RIGHT_SHIFT  &trans         &kp GRAVE     &none                 &none                  &none
            >;

            // Symbols: 左=カーソル左右 / 右=カーソル上下 (記号入力中のカーソル微調整用)
            sensor-bindings = <&inc_dec_kp RIGHT LEFT &inc_dec_kp DOWN UP>;
        };

        Mix_layer {
            display-name = "Mix";

            // ------------------------------------------------------------------------------------------------------------
            // | BTCLR | BT1  | BT2  |  BT3  |  BT4  |  BT5 |                |      |      |       |      |       |       |
            // |       | INS  | PSCR | GUI   |       |      |                | PGUP |      |   ^   |      |       |       |
            // |       | ALT  | CTRL | SHIFT |       | CAPS |                | PGDN |   <- |   v   |  ->  |  DEL  | BKSPC |
            // |       | UNDO | CUT  | COPY  | PASTE |      |      |  |      |      |      |       |      |       |       |
            //                |      |       |       |      |      |  |      |      |      |       |      |

            bindings = <
&kp F1  &kp F2  &kp F3   &kp F4  &kp F5  &to 0                                   &kp F11  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10
&kp N1  &kp N2  &kp N3   &kp N4  &kp N5  &trans                                  &kp F12  &kp N6  &kp N7  &kp N8  &kp N9  &kp N0
&none   &none   &none    &none   &none   &trans         &kp KP_NUMBER_3  &trans  &trans   &none   &none   &none   &none   &trans
&none   &none   &none    &kp TAB &trans  &kp BACKSPACE                           &trans   &trans  &kp N3  &none   &none   &none
            >;

            // Mix: 左=ブラウザタブ切替 (Ctrl+Tab) / 右=音量 (メディアコントロール用)
            // ※ Alt+Tab は修飾キー維持が必要なため encoder では難しく見送り
            sensor-bindings = <&inc_dec_kp LC(TAB) LC(LS(TAB)) &inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        Adjust_layer {
            display-name = "Adjust";

            // ----------------------------------------------------------------------------------------------------------------------------
            // | BTCLR  |  BT1    |  BT2    |   BT3   |   BT4   |   BT5   |                  |      |      |       |      |       |       |
            // | moDEBUG| RGB_HUD | RGB_HUI | RGB_SAD | RGB_SAI | RGB_EFF |                  |      |      |       |      |       |       |
            // | EXTPWR | RGB_BRD | RGB_BRI |         |         |         |                  |      |      |       |      |       |       |
            // |        |         |         |         |         |         | RGB_TOG | |      |      |      |       |      |       |       |
            //                    |         |         |         |         |         | |      |      |      |       |      |

            bindings = <
&bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_SEL 4   &to 0                                   &bt BT_CLR        &none              &none              &none  &none  &none
&bt BT_DISC 0  &bt BT_DISC 1  &bt BT_DISC 2  &bt BT_DISC 3  &bt BT_DISC 4  &none                                   &bt BT_CLR_ALL    &tog 0             &to 0              &none  &none  &none
&none          &none          &none          &none          &none          &bt BT_CLR_ALL  &kp KP_NUMBER_4  &trans  &none             &none              &none              &none  &none  &none
&none          &none          &none          &none          &none          &none                                   &ext_power EP_ON  &ext_power EP_TOG  &ext_power EP_OFF  &none  &none  &none
            >;
        };

        Navi_layer {
            display-name = "Navi";
            bindings = <
&none           &none  &none  &none   &none  &to 0                            &kp DELETE  &kp HOME  &kp PAGE_DOWN  &kp PG_UP  &kp END    &none
&kp LEFT_SHIFT  &none  &none  &none   &none  &none                            &none       &kp LEFT  &kp DOWN       &kp UP     &kp RIGHT  &none
&none           &none  &none  &none   &none  &none   &kp KP_NUMBER_5  &trans  &none       &trans    &trans         &none      &none      &none
&none           &none  &none  &mo 6   &trans &trans                           &none       &none     &kp N5         &none      &none      &kp RA(RCTRL)
            >;

            // Navi: 左=行頭/行末 / 右=ページ上下 (大移動用)
            sensor-bindings = <&inc_dec_kp END HOME &inc_dec_kp PG_DN PG_UP>;
        };

        KeyPad_layer {
            display-name = "NumPad";
            bindings = <
&none  &none  &none  &none  &none  &to 0                           &none            &kp KP_N7        &kp KP_N8        &kp KP_N9        &kp KP_MINUS  &kp KP_MULTIPLY
&none  &none  &none  &none  &none  &none                           &none            &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_N6        &kp KP_PLUS   &kp KP_DIVIDE
&none  &none  &none  &none  &none  &none  &kp KP_NUMBER_6  &trans  &none            &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_N3        &none         &none
&none  &none  &none  &none  &none  &mo 6                           &kp KP_N0        &kp KP_DOT       &kp KP_NUMBER_0  &none         &none            &none
            >;

            // NumPad: 左=+/- / 右=×/÷ (電卓的入力)
            sensor-bindings = <&inc_dec_kp KP_PLUS KP_MINUS &inc_dec_kp KP_MULTIPLY KP_DIVIDE>;
        };

        // Combo_layer 削除 (2026-05): 右手 HM 導入により sticky modifier combo が不要となり dead code 化
        // 旧 cb_kp_r-ctrl/shift/alt と入口だった lt_g 6 D も同時撤去済み

        Debug_layer {
            display-name = "Debug";

            // ----------------------------------------------------------------------------------------------------------------------------
            // | BTCLR  |  BT1    |  BT2    |   BT3   |   BT4   |   BT5   |                  |      |      |       |      |       |       |
            // | EXTPWR | BTCLR | RGB_HUI | RGB_SAD | RGB_SAI | RGB_EFF |                  |      |      |       |      |       |       |
            // |        | RGB_BRD | RGB_BRI |         |         |         |                  |      |      |       |      |       |       |
            // |        |         |         |         |         |         | RGB_TOG | |      |      |      |       |      |       |       |
            //                    |         |         |         |         |         | |      |      |      |       |      |

            bindings = <
&bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_SEL 4   &to 0                                   &none  &none        &none  &none  &none  &none
&bt BT_DISC 0  &bt BT_DISC 1  &bt BT_DISC 2  &bt BT_DISC 3  &bt BT_DISC 4  &none                                   &none  &none        &none  &none  &none  &none
&none          &none          &none          &none          &bootloader    &none          &kp KP_NUMBER_7  &trans  &none  &bootloader  &none  &none  &none  &none
&none          &none          &none          &none          &none          &none                                   &none  &none        &none  &none  &none  &none
            >;
        };
    };
};
