config SHIELD_CORNIX_LAYER9_LED_TEST
    def_bool $(shields_list_contains,cornix_layer9_led_test)

config CORNIX_LAYER9_LED_TEST
    bool "Cornix layer 9 LED test"
    depends on SHIELD_CORNIX_LAYER9_LED_TEST
    depends on LED_STRIP
    default y
    help
      Lights the local Cornix WS2812 LEDs while layer 9 is active.
