			phandle = < 0x16 >;
		};
		macro_m31: macro_m31 {
			compatible = "zmk,behavior-macro";
			#binding-cells = < 0x0 >;
			bindings = < &macro_tap &kp 0x7001e &kp 0x70014 &kp 0x70004 &kp 0x7001d &kp 0x7001f &kp 0x7001f &kp 0x70027 &kp 0x7001e >;
			phandle = < 0x17 >;
		};
